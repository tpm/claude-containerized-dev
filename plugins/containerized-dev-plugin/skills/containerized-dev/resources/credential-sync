#!/usr/bin/env bash
set -euo pipefail

# credential-sync — Sync ~/.claude/mnt/credentials/.credentials.json ↔ macOS Keychain.
# Pure bash. No FUSE, no Python, no system extensions.
#
# Usage:
#   credential-sync seed              # Keychain → shared file (one-shot)
#   credential-sync start [--fg]      # seed + start watcher (daemonizes by default)
#   credential-sync stop              # kill watcher
#   credential-sync status            # running or not

SHARED_DIR="$HOME/.claude/mnt/credentials"
SHARED_FILE="$SHARED_DIR/.credentials.json"
PID_FILE="$HOME/.claude/mnt/.credential-sync.pid"
KEYCHAIN_SERVICE="Claude Code-credentials"
KEYCHAIN_ACCOUNT="Claude Code"
FALLBACK_FILE="$HOME/.claude/.credentials.json"
POLL_INTERVAL=2

keychain_read() {
  security find-generic-password -s "$KEYCHAIN_SERVICE" -w 2>/dev/null || true
}

keychain_write() {
  local data="$1"
  [[ -z "$data" ]] && return
  security delete-generic-password -s "$KEYCHAIN_SERVICE" 2>/dev/null || true
  security add-generic-password -s "$KEYCHAIN_SERVICE" -a "$KEYCHAIN_ACCOUNT" -w "$data" 2>/dev/null
}

cmd_seed() {
  mkdir -p "$SHARED_DIR"
  local data
  data="$(keychain_read)"
  if [[ -z "$data" ]] && [[ -f "$FALLBACK_FILE" ]] && [[ -s "$FALLBACK_FILE" ]]; then
    data="$(cat "$FALLBACK_FILE")"
  fi
  if [[ -n "$data" ]]; then
    printf '%s' "$data" > "$SHARED_FILE"
    chmod 600 "$SHARED_FILE"
    echo "credential-sync: seeded shared file from keychain" >&2
  else
    echo "credential-sync: no credentials found in keychain or fallback file" >&2
    return 1
  fi
}

watch_loop() {
  local last_mtime=0
  while true; do
    if [[ -f "$SHARED_FILE" ]] && [[ -s "$SHARED_FILE" ]]; then
      local cur_mtime
      cur_mtime="$(stat -f %m "$SHARED_FILE" 2>/dev/null)" || cur_mtime=0
      if [[ "$cur_mtime" -ne "$last_mtime" ]] && [[ "$last_mtime" -ne 0 ]]; then
        local data
        data="$(cat "$SHARED_FILE")"
        if [[ -n "$data" ]]; then
          keychain_write "$data"
          # Also update fallback file
          printf '%s' "$data" > "$FALLBACK_FILE"
          chmod 600 "$FALLBACK_FILE"
        fi
      fi
      last_mtime="$cur_mtime"
    fi
    sleep "$POLL_INTERVAL"
  done
}

cmd_start() {
  local foreground=false
  [[ "${1:-}" == "--fg" ]] && foreground=true

  # Check for existing FUSE mount at shared dir
  if mount | grep -q " on $SHARED_DIR "; then
    echo "credential-sync: WARNING — FUSE mount detected at $SHARED_DIR" >&2
    echo "  Unmount it first: umount '$SHARED_DIR' or diskutil unmount '$SHARED_DIR'" >&2
    return 1
  fi

  # Already running?
  if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
    echo "credential-sync: already running (pid $(cat "$PID_FILE"))" >&2
    return 0
  fi

  cmd_seed || true

  if $foreground; then
    echo "credential-sync: watching in foreground (poll every ${POLL_INTERVAL}s)" >&2
    watch_loop
  else
    watch_loop &
    local pid=$!
    mkdir -p "$(dirname "$PID_FILE")"
    echo "$pid" > "$PID_FILE"
    echo "credential-sync: watcher started (pid $pid, poll every ${POLL_INTERVAL}s)" >&2
  fi
}

cmd_stop() {
  if [[ -f "$PID_FILE" ]]; then
    local pid
    pid="$(cat "$PID_FILE")"
    if kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null || true
      echo "credential-sync: stopped (pid $pid)" >&2
    else
      echo "credential-sync: not running (stale pid file)" >&2
    fi
    rm -f "$PID_FILE"
  else
    echo "credential-sync: not running" >&2
  fi
}

cmd_status() {
  if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
    echo "credential-sync: running (pid $(cat "$PID_FILE"))"
  else
    echo "credential-sync: not running"
    [[ -f "$PID_FILE" ]] && rm -f "$PID_FILE"
  fi
}

case "${1:-}" in
  seed)   cmd_seed ;;
  start)  cmd_start "${2:-}" ;;
  stop)   cmd_stop ;;
  status) cmd_status ;;
  *)
    echo "Usage: credential-sync {seed|start [--fg]|stop|status}" >&2
    exit 1
    ;;
esac
